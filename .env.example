# Copy to .env and fill in. Never commit real secrets.

NODE_ENV=production

# Server
PORT=3000
HOST=0.0.0.0
# Behind nginx, Cloudflare, Render, Railway, etc.:
TRUST_PROXY=1

# Session signing (required in production)
JWT_SECRET=

# Public URL (no trailing slash) — sitemap, SEO, canonical links
PUBLIC_SITE_URL=https://your-domain.com

# MySQL (Drizzle) — required for users, payments, notifications
DATABASE_URL=mysql://user:pass@host:3306/planexa

# Manus / OAuth login
OAUTH_SERVER_URL=
VITE_APP_ID=

# First admin user (openId from your IdP)
OWNER_OPEN_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Web Vitals / analytics (client)
# VITE_PUBLIC_SITE_URL=https://your-domain.com
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
# VITE_SEO_WEB_VITALS_ENDPOINT=
# VITE_SEO_DEBUG=0

# Optional: AWS S3 (if used for uploads)
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
