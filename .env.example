# Copy this file to .env and fill in your values. Never commit secrets.

NODE_ENV=production

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
# Set to 1 when behind nginx, Cloudflare, Render, Railway, etc.
TRUST_PROXY=1

# ─── Auth / Session ──────────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -base64 32
JWT_SECRET=

# OAuth provider (from your Manus/identity setup)
OAUTH_SERVER_URL=
VITE_APP_ID=

# openId of the first admin user (shown after first login in server logs)
OWNER_OPEN_ID=

# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Connection string from Supabase → Project Settings → Database → URI
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ─── Public URL ──────────────────────────────────────────────────────────────
# No trailing slash. Used for sitemap, SEO, canonical links, and email links.
PUBLIC_SITE_URL=https://your-domain.com
# VITE_PUBLIC_SITE_URL=https://your-domain.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get by running: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# Get from https://resend.com — free tier supports 3,000 emails/month
RESEND_API_KEY=re_...
# Must be from a verified domain in your Resend account
RESEND_FROM_EMAIL=noreply@your-domain.com

# ─── Optional: Analytics / SEO ───────────────────────────────────────────────
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
# VITE_SEO_WEB_VITALS_ENDPOINT=
# VITE_SEO_DEBUG=0

# ─── Optional: AWS S3 (file uploads) ─────────────────────────────────────────
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
